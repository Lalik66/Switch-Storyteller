# Database
POSTGRES_URL=postgresql://dev_user:dev_password@localhost:5432/postgres_dev

# Authentication — Better Auth
# Generate key using https://www.better-auth.com/docs/installation (min 32 chars)
BETTER_AUTH_SECRET=

# Google OAuth (optional — omit both to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (OAuth callbacks, sitemap, auth client baseURL)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# OpenRouter — chat + story generation (optional for chat; story routes need key at runtime)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Default chat model (see src/app/api/chat/route.ts)
OPENROUTER_MODEL=openai/gpt-5-mini
# Story loop — tiered models (see src/lib/env.ts defaults)
OPENROUTER_STORY_MODEL_CHEAP=google/gemini-flash-1.5
OPENROUTER_STORY_MODEL_PREMIUM=anthropic/claude-3-5-sonnet-20241022

# OpenAI — moderation API only (required by src/lib/env.ts for child-safety paths)
# https://platform.openai.com/api-keys — model is omni-moderation-latest in code
OPENAI_MODERATION_API_KEY=

# Vercel Blob — optional; without BLOB_READ_WRITE_TOKEN uploads use local public/ storage (dev)
BLOB_READ_WRITE_TOKEN=

# Resend — parent digest weekly email (Phase 2)
# https://resend.com/api-keys
RESEND_API_KEY=

# Vercel Cron — authenticates /api/cron/parent-digest in production
# Generate with: openssl rand -hex 32
# Must match the CRON_SECRET set in Vercel project env vars
CRON_SECRET=
